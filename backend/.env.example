DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Local default is SQLite. Set DATABASE_URL in staging/production to use Postgres.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Redis is used for caching/locks and as Celery broker/backend.
# For local dev with local Redis:
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True

ENABLE_CACHING=True
CACHE_TTL_RUNNING=300
CACHE_TTL_RESULT=86400
DAILY_RATELIMIT=200

AUTH0_DOMAIN=
AUTH0_ISSUER=
AUTH0_API_AUDIENCE=
FRONTEND_DASHBOARD_URL=http://localhost:5173

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
AI_DEFAULT_PROVIDER=anthropic
AI_SELECTION_STRATEGY=auto
AI_PROVIDER_PRIORITY=anthropic,openai
AI_COST_SCORE_ANTHROPIC=1.0
AI_COST_SCORE_OPENAI=1.2
